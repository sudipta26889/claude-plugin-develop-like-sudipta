{
  "_paths_note": "Paths below assume default install location (~/.claude/skills/develop-like-sudipta/hooks/). Run hooks/setup.sh to auto-update paths for your actual installation.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/skills/develop-like-sudipta/hooks/tdd-gate.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/skills/develop-like-sudipta/hooks/post-edit-check.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/skills/develop-like-sudipta/hooks/completion-gate.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/skills/develop-like-sudipta/hooks/state-saver.sh"
          }
        ]
      }
    ]
  }
}
